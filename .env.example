# Database (NeonDB)
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/kejari?sslmode=require

# Google Gemini AI
GEMINI_API_KEY=AIza...

# StarSender WhatsApp
STARSENDER_API_KEY=your_starsender_api_key
STARSENDER_DEVICE_ID=your_device_id

# better-auth
BETTER_AUTH_SECRET=minimum_32_chars_random_secret_here
BETTER_AUTH_URL=https://sahatekejaricimahi.id

# App URL (used for internal API calls, harus domain resmi di produksi)
NEXT_PUBLIC_APP_URL=https://sahatekejaricimahi.id

# URL publik untuk tautan di pesan WhatsApp (hindari localhost). Opsional jika WEB_URL produksi sudah benar.
# WHATSAPP_PUBLIC_APP_URL=https://sahatekejaricimahi.id
# Form laporan yang diarahkan dari bot WA (override lengkap, atau diisi otomatis dari domain di atas)
# WHATSAPP_REPORT_FORM_URL=https://sahatekejaricimahi.id/lapor

# (Opsional) Teks tambahan di halaman login /seksi (lupa sandi, kontak internal, dll.)
# NEXT_PUBLIC_SEKSI_BANTUAN=Contoh: WA Humas 08xx xxx / bagian umum.

# WhatsApp number for landing page CTA (format: 62xxx)
NEXT_PUBLIC_WA_NUMBER=628XXXXXXXXXX

# Webhook secret for StarSender
WEBHOOK_SECRET=random_webhook_secret_here

# Kode panel "Pengaturan akun" di /admin/pengaturan (standar 664599)
# ADMIN_SYSTEM_PIN=664599

# PIN PTSP front desk — dipakai jika belum diset di database lewat admin
# PTSP_FRONTDESK_PIN=1960

# Bootstrap admin + akun per seksi (npm run bootstrap:accounts)
# Wajib minimal 8 karakter untuk admin + default seluruh seksi.
SAHATE_BOOTSTRAP_PASSWORD=GantiDenganSandiKuatMinimal8
# Sandi berbeda per seksi (opsional — minimal 8 karakter). Kalau kosong pakai SAHATE_BOOTSTRAP_PASSWORD.
# SEKSI_PBIN_PASSWORD= 1945
# SEKSI_INTEL_PASSWORD=1946
# SEKSI_PIDUM_PASSWORD=1947
# SEKSI_PIDSUS_PASSWORD=1948
# SEKSI_DATUN_PASSWORD=1949
# SEKSI_PAPBB_PASSWORD=1950
#
# Daftar email & sandi efektif dari .env: npm run credentials:seksi
# Opsional — override URL target (default: BETTER_AUTH_URL lalu NEXT_PUBLIC_APP_URL)
# BOOTSTRAP_APP_URL=https://sahatekejaricimahi.id
# SAHATE_ADMIN_EMAIL=admin@kejari-cimahi.go.id
# SAHATE_ADMIN_NAME=Admin SAHATE
